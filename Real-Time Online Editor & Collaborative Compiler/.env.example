# ── Backend connection ────────────────────────────────────────────────────────
# URL of your deployed backend (Render / Railway).
# In development this defaults to http://localhost:5000 if not set.
# In Vercel, add this as an Environment Variable in the project settings.
VITE_BACKEND_URL=https://your-nexuscode-backend.onrender.com

# ── AI (optional) ─────────────────────────────────────────────────────────────
# Gemini API key for the AI assistant panel.
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
