# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In production (Render/Railway), set this to your Vercel domain:
#   ALLOWED_ORIGINS=https://your-app.vercel.app,https://custom-domain.com
# In development, defaults to localhost:3000,localhost:5173
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB connection string.
# For production, use MongoDB Atlas or a managed service.
# Example: mongodb+srv://user:pass@cluster.mongodb.net/nexuscode
MONGO_URI=mongodb://localhost:27017/nexuscode

# ── Auth ──────────────────────────────────────────────────────────────────────
# Secret key for JWT token signing. CHANGE THIS IN PRODUCTION.
# Generate a strong random string: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_change_in_production
